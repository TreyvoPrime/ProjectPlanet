<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/public/styles.css" />
  </head>
  <body class="planet-app">
    <div class="planet-bg" aria-hidden="true">
      <div class="planet-bg__stars"></div>
      <div class="planet-bg__glow planet-bg__glow--one"></div>
      <div class="planet-bg__glow planet-bg__glow--two"></div>
      <div class="planet-bg__grid"></div>
    </div>

    <main class="app-shell">
      <header class="hero-panel">
        <div class="hero-copy">
          <p class="eyebrow">Project Planet</p>
          <h1>Open packs, build your space collection, and battle the cosmos.</h1>
          <p class="hero-text">
            Pull real celestial objects, grow your owned collection, and bring one card at a time
            into the arena. Packs unlock cards. Collection stores only what you pulled. Battles
            turn your best finds into stardust.
          </p>
        </div>

        <div class="hero-side">
          <div class="hero-metrics">
            <article class="metric-card">
              <span class="metric-label">Stardust</span>
              <strong data-stat="stardust">300</strong>
              <small data-stat="stardust-note">Enough for a pack.</small>
            </article>
            <article class="metric-card">
              <span class="metric-label">Collection</span>
              <strong data-stat="owned-count">0</strong>
              <small data-stat="owned-note">No cards pulled yet.</small>
            </article>
            <article class="metric-card">
              <span class="metric-label">Record</span>
              <strong><span data-stat="wins">0</span> / <span data-stat="losses">0</span></strong>
              <small data-stat="battle-note">Every battle helps your aura grow.</small>
            </article>
            <article class="metric-card">
              <span class="metric-label">Daily Pack</span>
              <strong data-stat="daily-pack">Ready</strong>
              <small data-stat="daily-pack-note">Your free daily pull is waiting.</small>
            </article>
          </div>
          <div class="hero-preview card-preview" data-featured-card></div>
        </div>
      </header>

      <nav class="section-tabs" aria-label="Game sections">
        <button class="section-tab is-active" data-action="switch-tab" data-tab="packs" type="button">
          Packs
        </button>
        <button class="section-tab" data-action="switch-tab" data-tab="collection" type="button">
          Collection
        </button>
        <button class="section-tab" data-action="switch-tab" data-tab="battle" type="button">
          Battle
        </button>
        <button class="sound-button" data-action="toggle-sound" type="button">Sound: On</button>
      </nav>

      <section class="tab-panel is-active" data-panel="packs">
        <div class="section-card pack-layout">
          <div class="panel-copy">
            <p class="eyebrow">Pack Chamber</p>
            <h2>Open a four-card cosmic pack</h2>
            <p class="section-text">
              Packs reveal one card at a time with weighted rarity odds. Legendary and higher pulls
              get special effects. Duplicate pulls convert into bonus stardust.
            </p>
            <div class="action-row">
              <button class="primary-button" data-action="open-pack" type="button">Claim Daily Pack</button>
              <span class="status-pill" data-pack-cost>100 Stardust per paid pack</span>
            </div>
            <div class="status-box" data-pack-status>Ready to open a pack.</div>
            <div class="odds-list">
              <span>Common 52%</span>
              <span>Rare 24%</span>
              <span>Epic 12%</span>
              <span>Legendary 7%</span>
              <span>Mythic 4%</span>
              <span>Cosmic 1%</span>
            </div>
          </div>

          <div class="pack-visual">
            <div class="pack-shell" data-pack-shell>
              <div class="pack-shell__aura"></div>
              <div class="pack-shell__core"></div>
            </div>
            <div class="recent-pulls">
              <div class="recent-pulls__header">
                <h3>Latest Pulls</h3>
                <small data-card-count>Loading archive...</small>
              </div>
              <div class="recent-pulls__grid" data-recent-pulls></div>
            </div>
          </div>
        </div>
      </section>

      <section class="tab-panel" data-panel="collection">
        <div class="section-card">
          <div class="section-head">
            <div>
              <p class="eyebrow">Collection</p>
              <h2>Your owned archive</h2>
              <p class="section-text">
                Only cards you pull from packs appear here. Pick one to prepare it for battle.
              </p>
            </div>
            <div class="action-row compact">
              <button class="ghost-button" data-action="sort-rarity" type="button">Sort by rarity</button>
              <button class="ghost-button" data-action="sort-aura" type="button">Sort by power</button>
            </div>
          </div>

          <div class="collection-summary">
            <div class="summary-pill" data-category-summary>0 categories discovered</div>
            <div class="summary-pill" data-selection-summary>No card selected</div>
          </div>

          <div class="collection-grid" data-collection-grid></div>
        </div>
      </section>

      <section class="tab-panel" data-panel="battle">
        <div class="section-card battle-layout">
          <div class="battle-sidebar">
            <p class="eyebrow">Battle Mode</p>
            <h2>Send one card into the arena</h2>
            <p class="section-text">
              Select a card from your collection, then challenge a random rival from the full cosmic archive.
            </p>
            <div class="selected-card-slot" data-battle-selected></div>
            <div class="action-row">
              <button class="primary-button" data-action="battle-random" type="button">Battle Random Opponent</button>
            </div>
          </div>

          <div class="battle-main">
            <div class="battle-summary" data-battle-summary>
              Pull cards from packs first, then choose one from your collection to battle with it.
            </div>
            <div class="battle-history" data-battle-history></div>
          </div>
        </div>
      </section>
    </main>

    <section class="overlay hidden" data-pack-overlay aria-hidden="true">
      <div class="overlay-card pack-overlay-card">
        <div class="overlay-head">
          <div>
            <p class="eyebrow">Pack Opening</p>
            <h2>Cosmic reveal sequence</h2>
          </div>
          <button class="ghost-button" data-action="close-pack" type="button">Skip</button>
        </div>
        <div class="pack-stage" data-pack-drama>
          <div class="pack-stage__core"></div>
        </div>
        <div class="pack-results" data-pack-results></div>
      </div>
    </section>

    <section class="overlay hidden" data-battle-overlay aria-hidden="true">
      <div class="overlay-card battle-overlay-card">
        <div class="overlay-head">
          <div>
            <p class="eyebrow">Battle Result</p>
            <h2>Stat-by-stat showdown</h2>
          </div>
          <button class="ghost-button" data-action="close-battle" type="button">Close</button>
        </div>
        <div class="battle-versus">
          <article class="battle-combatant" data-battle-player></article>
          <div class="battle-versus__badge">VS</div>
          <article class="battle-combatant" data-battle-opponent></article>
        </div>
        <div class="battle-bars" data-battle-bars></div>
        <div class="battle-outcome" data-battle-result></div>
      </div>
    </section>

    <script src="/public/cosmic-card-library.js"></script>
    <script src="/public/cosmic-card-game.js"></script>
  </body>
</html>
